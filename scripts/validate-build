#!/usr/bin/env bash

echo "==> Typecheck (vue-tsc)"
npm run typecheck
TYPECHECK_STATUS=$?

echo
echo "==> Tests (vitest)"
npm test -- --run
TEST_STATUS=$?

echo
echo "==> Lint (eslint)"
npm run lint
LINT_STATUS=$?

echo
echo "===== Build Validation Summary ====="
[ $TYPECHECK_STATUS -eq 0 ] && echo "typecheck: PASS" || echo "typecheck: FAIL"
[ $TEST_STATUS -eq 0 ]      && echo "test:      PASS" || echo "test:      FAIL"
[ $LINT_STATUS -eq 0 ]      && echo "lint:      PASS" || echo "lint:      FAIL"

if [ $TYPECHECK_STATUS -ne 0 ] || [ $TEST_STATUS -ne 0 ] || [ $LINT_STATUS -ne 0 ]; then
  exit 1
fi
