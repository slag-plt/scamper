{
  "name": "scamper",
  "version": "3.5.0",
  "description": "The Scamper multimedia programming environment",
  "main": "./_build/js/index.js",
  "scripts": {
    "postinstall": "npm run generate-parser",
    "cli": "tsx src/cli/index.ts",
    "precli": "npm run generate-parser",
    "generate-parser": "node scripts/generate-parser.mjs",
    "typecheck": "vue-tsc -noEmit",
    "pretypecheck": "npm run generate-parser",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "prebuild": "npm run generate-parser",
    "preview": "vite preview",
    "deploy": "./scripts/deploy $npm_package_version",
    "clean": "rm -rf dist",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lezer/generator": "^1.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jsdom": "^21.1.3",
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.3.16",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-canvas-mock": "^1.1.3",
    "vue-tsc": "^3.2.6"
  },
  "//": "TODO: highlight.js is unused, but it's still used in commented out code. Remove it when we don't use it anymore (or keep it otherwise).",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.9.0",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/common": "^1.3.0",
    "@lezer/highlight": "^1.1.6",
    "@lezer/lr": "^1.3.10",
    "@tanstack/vue-virtual": "^3.13.23",
    "@types/showdown": "^2.0.6",
    "chart.js": "^4.5.1",
    "colorsys": "^1.0.22",
    "highlight.js": "^11.10.0",
    "papaparse": "^5.5.3",
    "showdown": "^2.1.0",
    "splitpanes": "^4.0.4",
    "vue": "^3.5.32",
    "webaudiofont": "^3.0.4"
  }
}
